<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card shadow border-0 mb-5">
            <div class="card-header bg-dark text-white py-4 text-center">
                <h3 class="mb-0">Generate Report</h3>
                <p class="mb-0 opacity-75"><%= template.name %></p>
            </div>

            <div class="card-body p-4 p-md-5">
                <form id="report-form" method="POST" action="/report-generate/<%= template.id %>" enctype="multipart/form-data">

                    <div class="row g-4">
                        <% form_fields.forEach(field => { %>

                            <%# ─── Dynamic Text Group (e.g. organizer, faculty, objective) ─── %>
                            <% if (field.type === 'dynamic-text-group') { %>
                                <div class="col-12 mt-4">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <label class="form-label fw-bold mb-0"><%= field.label %></label>
                                        <button type="button" class="btn btn-sm btn-outline-primary"
                                                onclick="addTextEntry('<%= field.name %>')">
                                            + Add Entry
                                        </button>
                                    </div>
                                    <div id="group-<%= field.name %>" class="d-flex flex-column gap-2">
                                        <div class="input-group dynamic-text-entry">
                                            <textarea name="<%= field.name %>[]" class="form-control" rows="2"
                                                      placeholder="Enter <%= field.label %> entry..."></textarea>
                                            <button type="button" class="btn btn-outline-danger"
                                                    onclick="removeEntry(this, '<%= field.name %>')">×</button>
                                        </div>
                                    </div>
                                </div>

                            <%# ─── Dynamic Image Group (e.g. event_image, feedback_image) ─── %>
                            <% } else if (field.type === 'dynamic-image-group') { %>
                                <div class="col-12 mt-4">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <label class="form-label fw-bold mb-0"><%= field.label %></label>
                                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                                onclick="addImageEntry('<%= field.name %>')">
                                            + Add Image
                                        </button>
                                    </div>
                                    <div id="group-<%= field.name %>" class="d-flex flex-column gap-2">
                                        <div class="input-group dynamic-image-entry">
                                            <input type="file" name="<%= field.name %>[]" class="form-control"
                                                   accept="image/*">
                                            <button type="button" class="btn btn-outline-danger"
                                                    onclick="removeEntry(this, '<%= field.name %>')">×</button>
                                        </div>
                                    </div>
                                </div>

                            <%# ─── Single Image Upload ─── %>
                            <% } else if (field.type === 'image') { %>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold"><%= field.label %></label>
                                    <input type="file" name="<%= field.name %>[]" class="form-control" accept="image/*">
                                    <div class="form-text">Upload an image for this placeholder.</div>
                                </div>

                            <%# ─── Date Field ─── %>
                            <% } else if (field.type === 'date') { %>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold"><%= field.label %></label>
                                    <input type="date" name="<%= field.name %>" class="form-control">
                                </div>

                            <%# ─── Dynamic Table (Multi-column loop) ─── %>
                            <% } else if (field.type === 'table') { %>
                                <div class="col-12 mt-4 table-container" id="table-container-<%= field.name %>">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <label class="form-label fw-bold mb-0 text-primary">
                                            <i class="fas fa-table me-2"></i><%= field.label %>
                                        </label>
                                        <button type="button" class="btn btn-sm btn-primary px-3 rounded-pill"
                                                onclick="addTableRow('<%= field.name %>')">
                                            <i class="fas fa-plus me-1"></i> Add Row
                                        </button>
                                    </div>
                                    
                                    <div class="table-responsive rounded shadow-sm border">
                                        <table class="table table-hover align-middle mb-0" id="table-<%= field.name %>">
                                            <thead class="table-light">
                                                <tr>
                                                    <% field.columns.forEach(col => { %>
                                                        <th class="py-3 text-uppercase font-size-xs text-muted fw-semibold">
                                                            <%= col.label %>
                                                        </th>
                                                    <% }) %>
                                                    <th style="width: 50px;"></th>
                                                </tr>
                                            </thead>
                                            <tbody class="bg-white">
                                                <tr class="table-row-item">
                                                    <% field.columns.forEach(col => { %>
                                                        <td>
                                                            <% if (col.type === 'srno') { %>
                                                                <span class="badge bg-secondary-subtle text-secondary border px-2 py-1">Auto</span>
                                                                <input type="hidden" name="<%= col.name %>" value="">
                                                            <% } else if (col.type === 'date') { %>
                                                                <input type="date" name="<%= col.name %>" class="form-control form-control-sm border-0 bg-light">
                                                            <% } else if (col.type === 'time') { %>
                                                                <input type="time" name="<%= col.name %>" class="form-control form-control-sm border-0 bg-light">
                                                            <% } else if (col.type === 'timerange') { %>
                                                                <div class="d-flex align-items-center gap-1 timerange-container">
                                                                    <input type="time" class="form-control form-control-sm timerange-from border-0 bg-light" title="From">
                                                                    <span class="text-muted small">to</span>
                                                                    <input type="time" class="form-control form-control-sm timerange-to border-0 bg-light" title="To">
                                                                    <input type="hidden" name="<%= col.name %>" class="timerange-combined">
                                                                </div>
                                                            <% } else { %>
                                                                <% 
                                                                    const isLong = col.label.toLowerCase().includes('roll no') || col.label.toLowerCase().includes('name') || col.label.toLowerCase().includes('guide');
                                                                    const rowCount = isLong ? 3 : 1;
                                                                %>
                                                                <textarea name="<%= col.name %>" 
                                                                          class="form-control form-control-sm border-0 bg-light-subtle auto-expand" 
                                                                          rows="<%= rowCount %>"
                                                                          oninput="autoResize(this)"></textarea>
                                                            <% } %>
                                                        </td>
                                                    <% }) %>
                                                    <td class="text-end pe-3">
                                                        <button type="button" class="btn btn-link link-danger p-0 opacity-50 hover-opacity-100" 
                                                                onclick="removeTableRow(this, '<%= field.name %>')">
                                                            <i class="fas fa-trash-alt"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                    <%# Hidden storage for the actual serialized JSON array of rows %>
                                    <input type="hidden" id="hidden-<%= field.name %>" name="<%= field.name %>" value="">
                                </div>

                            <%# ─── Default: Long Textarea ─── %>
                            <% } else { %>
                                <div class="col-12">
                                    <label class="form-label fw-bold"><%= field.label %></label>
                                    <textarea name="<%= field.name %>" class="form-control auto-expand" rows="3"
                                              oninput="autoResize(this)"
                                              placeholder="Enter <%= field.label %>..."></textarea>
                                </div>
                            <% } %>

                        <% }) %>
                    </div>

                    <div class="mt-5 pt-3 border-top d-flex gap-3 justify-content-end">
                        <button type="submit" name="action" value="preview" class="btn btn-outline-info btn-lg shadow-sm px-md-5">
                            <i class="bi bi-eye"></i> Generate & Preview
                        </button>
                        <button type="submit" name="action" value="download" class="btn btn-primary btn-lg shadow px-md-5">
                            <i class="bi bi-download"></i> Generate & Download
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Add FontAwesome for icons if not already in layout -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    .bg-light-subtle { background-color: #f8f9fa; }
    .font-size-xs { font-size: 0.75rem; }
    .hover-opacity-100:hover { opacity: 1 !important; }
    .table-container { border-radius: 8px; }
    .form-control:focus { background-color: #fff !important; border-color: #0d6efd !important; box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1) !important; }

    /* Auto-expand styles */
    textarea.auto-expand {
        resize: none;
        overflow: hidden;
        min-height: 38px;
        transition: height 0.1s ease;
    }

    .timerange-container .form-control {
        min-width: 80px;
        padding: 0.25rem 0.4rem;
    }
</style>

<script>
    function autoResize(textarea) {
        textarea.style.height = 'auto';
        textarea.style.height = textarea.scrollHeight + 'px';
    }

    // Initialize on page load
    window.addEventListener('load', () => {
        document.querySelectorAll('textarea.auto-expand').forEach(textarea => {
            if (textarea.value) autoResize(textarea);
        });
    });

    function addTextEntry(groupName) {
        const container = document.getElementById('group-' + groupName);
        const div = document.createElement('div');
        div.className = 'input-group dynamic-text-entry mt-2';
        div.innerHTML = `
            <textarea name="${groupName}[]" class="form-control auto-expand" rows="2"
                      oninput="autoResize(this)"
                      placeholder="Enter entry..."></textarea>
            <button type="button" class="btn btn-outline-danger"
                    onclick="removeEntry(this, '${groupName}')">×</button>
        `;
        container.appendChild(div);
    }

    function addImageEntry(groupName) {
        const container = document.getElementById('group-' + groupName);
        const div = document.createElement('div');
        div.className = 'input-group dynamic-image-entry';
        div.innerHTML = `
            <input type="file" name="${groupName}[]" class="form-control" accept="image/*">
            <button type="button" class="btn btn-outline-danger"
                    onclick="removeEntry(this, '${groupName}')">×</button>
        `;
        container.appendChild(div);
    }

    function removeEntry(btn, groupName) {
        const container = document.getElementById('group-' + groupName);
        const entries = container.querySelectorAll('.dynamic-text-entry, .dynamic-image-entry');
        if (entries.length > 1) {
            btn.closest('.input-group').remove();
        }
    }

    // ─── Table Management ───

    function addTableRow(tableName) {
        const tbody = document.querySelector(`#table-${tableName} tbody`);
        const firstRow = tbody.querySelector('tr');
        const newRow = firstRow.cloneNode(true);
        
        // Clear value of all inputs and textareas in the cloned row
        newRow.querySelectorAll('input:not([type="hidden"]), textarea').forEach(input => {
            input.value = '';
            if (input.tagName.toLowerCase() === 'textarea') {
                input.style.height = ''; // Reset height to initial CSS default
            }
        });

        // Clear timerange hidden values
        newRow.querySelectorAll('.timerange-combined').forEach(h => h.value = '');
        
        tbody.appendChild(newRow);
    }

    function removeTableRow(btn, tableName) {
        const tbody = document.querySelector(`#table-${tableName} tbody`);
        const rows = tbody.querySelectorAll('.table-row-item');
        if (rows.length > 1) {
            btn.closest('tr').remove();
        } else {
            // If it's the last row, just clear it
            rows[0].querySelectorAll('input, textarea').forEach(input => {
                input.value = '';
            });
        }
    }

    document.getElementById('report-form').addEventListener('submit', function(e) {
        let isValid = true;
        let errorMessages = [];

        // 4) Make all fields mandatory (check visible inputs, except inside tables unless date/time)
        const allVisibleInputs = document.querySelectorAll('input:not([type="hidden"]):not([type="file"]), select, textarea');
        for (let input of allVisibleInputs) {
            let isTableDateOrTime = false;
            
            if (input.closest('table')) {
                const type = input.getAttribute('type');
                if (type === 'date' || type === 'time') {
                    isTableDateOrTime = true;
                } else {
                    continue; // Exclude normal table data
                }
            }

            if (!input.value.trim() && !input.closest('.date-helper')) {
                isValid = false;
                input.classList.add('is-invalid');
                
                if (isTableDateOrTime) {
                    const msg = 'Date and Time fields inside tables are strictly mandatory.';
                    if (!errorMessages.includes(msg)) errorMessages.push(msg);
                } else {
                    const msg = 'All root fields are mandatory. Please fill in all general fields outside tables.';
                    if (!errorMessages.includes(msg)) errorMessages.push(msg);
                }
            } else {
                input.classList.remove('is-invalid');
            }
        }

        // 1) Marks should be numeric
        for (let input of allVisibleInputs) {
            const nameAttr = (input.name || '').toLowerCase();
            if (nameAttr.includes('marks')) {
                if (isNaN(input.value.trim()) || input.value.trim() === '') {
                    isValid = false;
                    input.classList.add('is-invalid');
                    if (!errorMessages.includes('Fields requesting "marks" must contain only numeric values.')) {
                        errorMessages.push('Fields requesting "marks" must contain only numeric values.');
                    }
                }
            }
        }

        // 3) For time range, ensure from time is <= to time
        document.querySelectorAll('.timerange-container').forEach(container => {
            const fromInput = container.querySelector('.timerange-from');
            const toInput = container.querySelector('.timerange-to');
            const from = fromInput.value;
            const to = toInput.value;
            
            if (from && to) {
                if (from >= to) {
                    isValid = false;
                    fromInput.classList.add('is-invalid');
                    toInput.classList.add('is-invalid');
                    if (!errorMessages.includes('In Time ranges, the "From Time" must be strictly earlier than the "To Time"')) {
                        errorMessages.push('In Time ranges, the "From Time" must be strictly earlier than the "To Time"');
                    }
                } else {
                    fromInput.classList.remove('is-invalid');
                    toInput.classList.remove('is-invalid');
                }
            }
        });

        // 2) Ensure start date is before end date (Scan within the same table row or form scope)
        const allRows = document.querySelectorAll('.table-row-item, form'); // Also checking globally for forms
        allRows.forEach(row => {
            const dateInputs = row.querySelectorAll('input[type="date"]');
            let startDates = [];
            let endDates = [];
            
            dateInputs.forEach(d => {
                const name = (d.name || '').toLowerCase();
                if (name.includes('start')) startDates.push(d);
                if (name.includes('end')) endDates.push(d);
            });
            
            if (startDates.length > 0 && endDates.length > 0) {
                const sd = startDates[0];
                const ed = endDates[0];
                if (sd.value && ed.value) {
                    if (new Date(sd.value) > new Date(ed.value)) {
                        isValid = false;
                        sd.classList.add('is-invalid');
                        ed.classList.add('is-invalid');
                        if (!errorMessages.includes('Start Date must be before the End Date.')) {
                            errorMessages.push('Start Date must be before the End Date.');
                        }
                    }
                }
            }
        });

        // Combine timerange hidden inputs
        document.querySelectorAll('.timerange-container').forEach(container => {
            const from = container.querySelector('.timerange-from').value;
            const to = container.querySelector('.timerange-to').value;
            const combinedInput = container.querySelector('.timerange-combined');
            if (from && to) combinedInput.value = `${from} to ${to}`;
            else if (from || to) combinedInput.value = from || to;
            else combinedInput.value = '';
        });

        const tableContainers = document.querySelectorAll('.table-container');
        
        tableContainers.forEach(container => {
            const tableId = container.id.replace('table-container-', '');
            const table = document.getElementById('table-' + tableId);
            const rows = table.querySelectorAll('.table-row-item');
            const tableData = [];

            rows.forEach(row => {
                const rowData = {};
                row.querySelectorAll('input, textarea, select').forEach(input => {
                    if (input.name) {
                        rowData[input.name] = input.value;
                    }
                });
                
                // Only add if row has some data (ignore empty rows unless it's just sr_no)
                const hasRealData = Object.entries(rowData).some(([k, v]) => {
                    const lowK = k.toLowerCase();
                    const isSpecial = lowK.includes('sr_no') || lowK.includes('srno') || lowK.includes('sno') || lowK.includes('sl_no');
                    return !isSpecial && v.trim() !== '';
                });

                if (hasRealData) {
                    tableData.push(rowData);
                }
            });

            if (tableData.length === 0) {
                isValid = false;
                table.style.border = '2px solid red';
                if (!errorMessages.includes('All tables must contain at least one row of data.')) {
                    errorMessages.push('All tables must contain at least one row of data.');
                }
            } else {
                table.style.border = '';
            }

            const hiddenInput = document.getElementById('hidden-' + tableId);
            if (hiddenInput) {
                hiddenInput.value = JSON.stringify(tableData);
            }
        });

        if (!isValid) {
            e.preventDefault();
            alert("Validation Failed:\n\n- " + errorMessages.join("\n- "));
            return false;
        }
    });
</script>
