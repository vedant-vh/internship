<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h2 class="mb-0">Report Templates</h2>
        <p class="text-muted mt-1">Select a report template to generate a new document report.</p>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
        <% if (user.role === 'ADMIN') { %>
            <a href="/report-templates/upload" class="btn btn-success shadow-sm">
                + Upload Report Template
            </a>
        <% } %>
    </div>
</div>

<% if (templates.length > 0) { %>
<div class="row mb-3">
    <div class="col-md-5 mb-2 mt-md-0">
        <input type="text" id="reportTemplateSearch" class="form-control shadow-sm" placeholder="Search templates by name...">
    </div>
</div>
<% } %>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <% if (templates.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="ps-4">Template Name</th>
                            <th scope="col">Uploaded On</th>
                            <th scope="col" class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% templates.forEach(template => { %>
                            <tr class="template-row" data-name="<%= template.name %>">
                                <td class="ps-4 fw-medium"><%= template.name %></td>
                                <td><span class="text-muted"><%= template.createdAt.toLocaleString() %></span></td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a href="/report-forms/<%= template.id %>" class="btn btn-primary btn-sm px-3">
                                            Generate
                                        </a>
                                        <a href="/report-templates/<%= template.id %>" class="btn btn-outline-secondary btn-sm">
                                            Details
                                        </a>
                                        <% if (user.role === 'ADMIN') { %>
                                            <button type="button" class="btn btn-outline-info btn-sm" onclick="renameTemplate(this.getAttribute('data-id'), this.getAttribute('data-name'))" data-id="<%= template.id %>" data-name="<%= template.name %>">
                                                Rename
                                            </button>
                                            <form action="/report-templates/<%= template.id %>/delete" method="POST" class="d-inline"
                                                  onsubmit="return confirm('Remove this report template from the portal? (Files on disk are preserved.)')">
                                                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                            </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <div class="text-muted mb-3" style="font-size: 3rem;">📋</div>
                <h5 class="text-muted">No report templates uploaded yet.</h5>
                <% if (user.role === 'ADMIN') { %>
                    <a href="/report-templates/upload" class="btn btn-outline-success mt-3">Upload Report Template</a>
                <% } %>
            </div>
        <% } %>
    </div>
</div>

<script>
    // Search functionality
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('reportTemplateSearch');
        if (searchInput) {
            searchInput.addEventListener('keyup', function() {
                const term = this.value.toLowerCase();
                const rows = document.querySelectorAll('.template-row');
                rows.forEach(row => {
                    const name = row.getAttribute('data-name').toLowerCase();
                    if (name.includes(term)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            });
        }
    });

    // Rename functionality for Admin
    function renameTemplate(id, currentName) {
        const newName = prompt('Enter new report template name:', currentName);
        if (newName && newName.trim() !== '' && newName.trim() !== currentName) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/report-templates/' + id + '/rename';
            
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'newName';
            input.value = newName.trim();
            
            form.appendChild(input);
            document.body.appendChild(form);
            form.submit();
        }
    }
</script>
