<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="row mb-4 align-items-center">
            <div class="col">
                <h2 class="mb-0">Upload Report Template</h2>
                <p class="text-muted mt-1">Upload a .docx file with <code>{{placeholders}}</code> to create a new report template.</p>
            </div>
            <div class="col-auto">
                <a href="/report-templates" class="btn btn-outline-secondary btn-sm">← Back</a>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-md-5">
                <form action="/report-templates/upload" method="POST" enctype="multipart/form-data">
                    <div class="mb-4">
                        <label for="name" class="form-label fw-bold">Template Name</label>
                        <input type="text" name="name" id="name" class="form-control form-control-lg" placeholder="e.g. Training Program Report" required>
                    </div>
                    <div class="mb-5">
                        <label for="template_file" class="form-label fw-bold">Template File (.docx)</label>
                        <input type="file" name="template_file" id="template_file" class="form-control" accept=".docx" required>
                        <div class="form-text">Must be a <strong>.docx</strong> file using <code>{{double brace}}</code> placeholders.</div>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-success btn-lg shadow-sm">Upload & Parse Template</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
