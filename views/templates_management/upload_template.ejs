<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">Upload Template</h2>
            <a href="/templates" class="btn btn-outline-secondary btn-sm">
                &larr; Back to Templates
            </a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                
                <p class="text-muted mb-4">
                    Upload a standardized DOCX document. Use Jinja-like placeholders (e.g., {{field_name}}) for standard fields and special markers for tables.
                </p>

                <form method="POST" action="/templates/upload" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="name" class="form-label">Template Name</label>
                        <input type="text" name="name" id="name" class="form-control" required placeholder="e.g., Unit Test Schedule">
                    </div>

                    <div class="mb-4">
                        <label for="template_file" class="form-label">DOCX File</label>
                        <input type="file" name="template_file" id="template_file" class="form-control" required accept=".docx">
                        <div class="form-text">Please upload a valid .docx file.</div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a href="/templates" class="btn btn-light me-md-2">Cancel</a>
                        <button type="submit" class="btn btn-primary px-4 shadow-sm">
                            Upload Template
                        </button>
                    </div>
                </form>

            </div>
        </div>
        
    </div>
</div>
