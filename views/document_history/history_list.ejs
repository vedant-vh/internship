<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h2 class="mb-0">Document History</h2>
        <p class="text-muted mt-1">A list of all recently generated documents.</p>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <% if (history.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="ps-4">Document Title</th>
                            <th scope="col">Generated On</th>
                            <th scope="col" class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% history.forEach(doc => { %>
                            <tr>
                                <td class="ps-4 fw-medium">
                                    <%= doc.template ? doc.template.name : 'Deleted Template' %>
                                </td>
                                <td>
                                    <span class="text-muted"><%= doc.createdAt.toLocaleString() %></span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a href="/generate/preview/<%= doc.id %>" class="btn btn-outline-info btn-sm">
                                            Preview
                                        </a>
                                        <a href="/history/download/<%= doc.id %>" class="btn btn-outline-primary btn-sm">
                                            Download DOCX
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <div class="text-muted mb-3" style="font-size: 3rem;">🗃️</div>
                <h5 class="text-muted">No documents generated yet.</h5>
                <p class="text-muted">Generated documents will appear here for easy access.</p>
            </div>
        <% } %>
    </div>
</div>
